{
    "name": "@solracer/oracle",
    "version": "0.1.0",
    "private": true,
    "description": "Oracle ingestion and track bucket pipeline for SolRacer",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "check": "tsc --noEmit",
        "dev": "node --env-file=.env -r ts-node/register src/index.ts",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:db": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@solana/web3.js": "^1.98.4",
        "dotenv": "^17.3.1",
        "pg": "^8.13.1"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/pg": "^8.11.10",
        "cross-env": "^10.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
